  <name>No-IP DUC</name>
  <summary>Keep your dynamic IP address updated with No-IP DNS</summary>
  <description>
    <p>
      No-IP Dynamic Update Client (DUC) monitors your public IP address and
      automatically updates your No-IP hostname records whenever it changes.
      It includes a graphical interface for managing hostnames, viewing status,
      and controlling a background systemd service.
    </p>
  </description>
  <launchable type="desktop-id">com.noip.DUC.desktop</launchable>
  <url type="homepage">https://www.noip.com</url>
  <developer id="com.noip">
    <name>No-IP</name>
  </developer>
  <branding>
    <color type="primary" scheme_preference="light">#8dbd09</color>
    <color type="primary" scheme_preference="dark">#111216</color>
  </branding>
